{
  "expo": {
    "name": "QuickBill Pro",
    "slug": "quickbill-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quickbill.pro"
    },
    "android": {
      "package": "com.quickbill.pro",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-camera"
    ],
    "scheme": "quickbillpro",
    "experiments": {
      "typedRoutes": true
    }
  }
}
