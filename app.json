{
  "expo": {
    "name": "QuickBill Pro",
    "slug": "quickbill-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quickbill.pro"
    },
    "android": {
      "package": "com.quickbill.pro",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-camera",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-font",
      "@react-native-google-signin/google-signin"
    ],
    "scheme": "quickbillpro",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "googleWebClientId": "331043313449-daqkne4kkolc2bh9o3mqsfv9q7hevs9s.apps.googleusercontent.com",
      "eas": {
        "projectId": "b7e9cfda-6290-4474-a5d8-4dadc8c1dc32"
      }
    }
  }
}
